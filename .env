PORT=5000
NODE_ENV=production

# --- MongoDB ---
MONGODB_URI=your_mongodb_uri

# --- JWT ---
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=8h

# --- CORS ---
CLIENT_URL=https://xrise-helpdesk-client.vercel.app

# --- Groq AI ---
GROQ_API_KEY=your_groq_api_key

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=20